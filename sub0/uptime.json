        "title": "All Services Status",
        "transformations": [
          {
            "id": "joinByField",
            "options": {
              "byField": "instance",
              "mode": "outer"
            }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "Time 1": true,
                "Time 2": true,
                "Time 3": true,
                "__name__": true,
                "__name__ 1": true,
                "__name__ 2": true,
                "__name__ 3": true,
                "job": true,
                "job 1": true,
                "job 2": true,
                "job 3": true
              },
              "indexByName": {
                "instance": 0,
                "Value #Status": 1,
                "Value #Duration": 2,
                "Value #HTTP": 3
              },
              "renameByName": {
                "Value #Duration": "Response Time",
                "Value #HTTP": "HTTP Status",
                "Value #Status": "Status",
                "instance": "Service"
              }
