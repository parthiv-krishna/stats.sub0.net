                {
                  "color": "orange",
                  "value": 0.9
                },
                {
                  "color": "yellow",
                  "value": 0.95
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "unit": "percentunit"
          },
          "overrides": []
