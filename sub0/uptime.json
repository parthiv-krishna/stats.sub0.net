            "fields": "",
            "values": false
          },
          "showPercentChange": false,
          "textMode": "auto",
          "wideLayout": true
        },
        "pluginVersion": "12.1.0-244117",
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "deof1yw2v2olcb"
            },
            "editorMode": "code",
            "expr": "sum(probe_success{job=\"blackbox\"}) / count(probe_success{job=\"blackbox\"})",
            "legendFormat": "Uptime",
            "range": true,
            "refId": "A"
          }
        ],
        "title": "Overall Uptime",
        "type": "stat"
